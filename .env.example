# =============================================================================
# Comics Trunk - Environment Variables
# =============================================================================
# IMPORTANT: In production (cPanel), set these via the cPanel Node.js Selector
# UI under "Environment Variables". Do NOT use .env files in production.
# This file documents all required variables for development and cPanel setup.
# =============================================================================

# --- Database ---
# MySQL connection string (cPanel: create database via MySQL Databases panel)
DATABASE_URL="mysql://user:password@localhost:3306/comicstrunk"

# --- Authentication ---
# JWT secrets (generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
JWT_ACCESS_SECRET="change-me-generate-a-64-byte-hex-string"
JWT_REFRESH_SECRET="change-me-generate-a-different-64-byte-hex-string"

# --- Application URLs ---
# Frontend URL (used for CORS origin)
WEB_URL="https://comicstrunk.com"

# API URL (used by frontend to call API)
API_URL="https://api.comicstrunk.com"

# --- Runtime ---
# Node environment (production | development)
NODE_ENV="development"

# Server port (cPanel Passenger ignores this — it captures listen() directly)
PORT=3001

# --- Database Backup (used by scripts/backup-db.sh) ---
# These are separate from DATABASE_URL for the mysqldump CLI tool
DB_HOST="localhost"
DB_PORT="3306"
DB_NAME="comicstrunk"
DB_USER="comicstrunk_user"
DB_PASSWORD="your-database-password"
BACKUP_DIR="/home/username/backups/db"
BACKUP_RETENTION_DAYS=7
