# Environment variables declared in this file are automatically made available to Prisma.
# See the documentation for more detail: https://pris.ly/d/prisma-schema#accessing-environment-variables-from-the-schema

# Prisma supports the native connection string format for PostgreSQL, MySQL, SQLite, SQL Server, MongoDB and CockroachDB.
# See the documentation for all the connection string options: https://pris.ly/d/connection-strings

DATABASE_URL="mysql://root:admin@localhost:3306/comicstrunk"

# JWT secrets (dev only — generate strong random values for production)
JWT_ACCESS_SECRET="dev-access-secret-change-in-production-32chars!"
JWT_REFRESH_SECRET="dev-refresh-secret-change-in-production-32chars!"

# Web URL for CORS and password reset links
WEB_URL="http://localhost:3000"

# Cloudinary (optional — image uploads return empty URLs when not configured)
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# Mercado Pago credentials (use TEST- prefix for sandbox)
MERCADOPAGO_ACCESS_TOKEN=""
# Webhook signature secret from MP dashboard
MERCADOPAGO_WEBHOOK_SECRET=""
# Public URL for webhook callbacks (use ngrok for local dev)
API_PUBLIC_URL="http://localhost:3001"

# Stripe credentials (subscription billing)
# Get keys from Stripe Dashboard -> Developers -> API keys
STRIPE_SECRET_KEY=""              # sk_test_xxx for sandbox, sk_live_xxx for production
STRIPE_WEBHOOK_SECRET=""          # whsec_xxx from Stripe CLI or Dashboard
STRIPE_PUBLISHABLE_KEY=""         # pk_test_xxx (passed to frontend for Checkout redirect)
