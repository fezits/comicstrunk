# Environment variables declared in this file are automatically made available to Prisma.
# See the documentation for more detail: https://pris.ly/d/prisma-schema#accessing-environment-variables-from-the-schema

# Prisma supports the native connection string format for PostgreSQL, MySQL, SQLite, SQL Server, MongoDB and CockroachDB.
# See the documentation for all the connection string options: https://pris.ly/d/connection-strings

DATABASE_URL="mysql://root:admin@localhost:3306/comicstrunk"

# JWT secrets (dev only — generate strong random values for production)
JWT_ACCESS_SECRET="dev-access-secret-change-in-production-32chars!"
JWT_REFRESH_SECRET="dev-refresh-secret-change-in-production-32chars!"

# Web URL for CORS and password reset links
WEB_URL="http://localhost:3000"

# Cloudflare R2 (cover image storage — recommended)
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_ENDPOINT=""                    # https://{account_id}.r2.cloudflarestorage.com
R2_BUCKET_NAME="comicstrunk"
R2_PUBLIC_URL=""                  # https://covers.comicstrunk.com

# Cloudinary (optional legacy — image uploads)
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# PIX Static Payment (direct PIX without intermediary)
# Used by pix-utils to generate BR Code + QR code
PIX_KEY=""                        # Email, phone, CPF, or random PIX key
MERCHANT_NAME=""                  # Max 25 chars, no accents
MERCHANT_CITY=""                  # Max 15 chars, no accents

# Mercado Pago credentials (optional — used as fallback if PIX_KEY is not set)
MERCADOPAGO_ACCESS_TOKEN=""
# Webhook signature secret from MP dashboard
MERCADOPAGO_WEBHOOK_SECRET=""
# Public URL for webhook callbacks (use ngrok for local dev)
API_PUBLIC_URL="http://localhost:3001"

# Stripe credentials (subscription billing)
# Get keys from Stripe Dashboard -> Developers -> API keys
STRIPE_SECRET_KEY=""              # sk_test_xxx for sandbox, sk_live_xxx for production
STRIPE_WEBHOOK_SECRET=""          # whsec_xxx from Stripe CLI or Dashboard
STRIPE_PUBLISHABLE_KEY=""         # pk_test_xxx (passed to frontend for Checkout redirect)

# Resend (transactional emails)
# Get API key from Resend Dashboard -> API Keys -> Create API Key (re_xxx)
RESEND_API_KEY=""
# From address — requires verified domain in Resend Dashboard -> Domains
RESEND_FROM_EMAIL="Comics Trunk <noreply@comicstrunk.com.br>"

# Cover scan (busca de capa por foto) — Fase 1
COVER_SCAN_DAILY_LIMIT=30

# Cloudflare Workers AI (Fase 2 scan-capa)
# Conta com Workers AI habilitado. Token precisa de permissao Workers AI: Read + Edit.
# Account ID: visivel no dashboard CF, canto direito.
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_AI_MODEL=@cf/meta/llama-3.2-11b-vision-instruct

# MetronDB (Fase 3 scan-capa - busca externa)
# Sign-up gratuito em https://metron.cloud/accounts/signup/
# Auth via HTTP Basic. Rate limits: 20/min burst, 5000/dia sustained.
# Atribuicao "Powered by Metron" obrigatoria (CC BY-SA 4.0).
METRON_USERNAME=
METRON_PASSWORD=
